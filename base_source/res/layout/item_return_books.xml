<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:orientation="vertical" android:padding="@dimen/margin_5dp" android:layout_width="fill_parent" android:layout_height="wrap_content"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <CheckBox android:textSize="@dimen/font_14sp" android:id="@id/cbBookName" android:layout_width="fill_parent" android:layout_height="wrap_content" android:text="Book name - Book Code" style="@style/radio_button_style" />
    <RelativeLayout android:orientation="horizontal" android:layout_width="fill_parent" android:layout_height="wrap_content">
        <TextView android:textSize="@dimen/font_12sp" android:id="@id/tvIssueDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Issued Date" android:layout_centerVertical="true" android:layout_alignParentStart="true" />
        <EditText android:textSize="@dimen/font_12sp" android:id="@id/etPrice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="500" android:layout_centerVertical="true" android:layout_alignParentEnd="true" />
    </RelativeLayout>
    <LinearLayout android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content">
        <TextView android:textSize="@dimen/font_12sp" android:layout_gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/status">
            <requestFocus />
        </TextView>
        <Spinner android:id="@id/sp_return_status" android:visibility="visible" android:layout_width="wrap_content" android:layout_height="wrap_content" style="@style/spinner_style" />
    </LinearLayout>
</LinearLayout>