<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:orientation="vertical" android:layout_width="fill_parent" android:layout_height="fill_parent"
  xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <RelativeLayout android:layout_width="fill_parent" android:layout_height="wrap_content">
        <include android:id="@id/toolbar_patientdetail" layout="@layout/toolbar" />
        <LinearLayout android:gravity="center" android:orientation="horizontal" android:id="@id/llMainTabs" android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_below="@id/toolbar_patientdetail">
            <Button android:textColor="#ffffffff" android:layout_gravity="center" android:id="@id/btnNewPatients" android:background="@drawable/red_patch_sharp" android:layout_width="0.0dip" android:layout_height="@dimen/margin_40dp" android:text="@string/new_patient" android:layout_weight="1.0" android:onClick="newPatient" android:textAllCaps="false" />
            <Button android:textColor="@color/colorPrimaryGreen" android:layout_gravity="center" android:id="@id/btnRepeatedPatients" android:background="@drawable/clinicborder_sharp" android:layout_width="@dimen/margin_0dp" android:layout_height="@dimen/margin_40dp" android:text="@string/repeated_patient" android:layout_weight="1.0" android:onClick="repeatedPatient" android:textAllCaps="false" />
        </LinearLayout>
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout android:id="@id/swipeRefreshLayoutAll" android:visibility="visible" android:layout_width="fill_parent" android:layout_height="fill_parent" android:layout_above="@id/llTotalAmount" android:layout_below="@id/llMainTabs">
            <LinearLayout android:orientation="vertical" android:layout_width="fill_parent" android:layout_height="fill_parent">
                <ListView android:id="@id/lvNewPatientList" android:visibility="visible" android:layout_width="fill_parent" android:layout_height="wrap_content" android:choiceMode="multipleChoice" />
                <ListView android:id="@id/lvRepeatedPatientList" android:visibility="gone" android:layout_width="fill_parent" android:layout_height="wrap_content" android:choiceMode="multipleChoice" />
            </LinearLayout>
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
        <TextView android:gravity="center" android:layout_gravity="center" android:id="@id/tv_no_data_found" android:visibility="gone" android:layout_width="fill_parent" android:layout_height="fill_parent" android:text="No patient found" />
        <LinearLayout android:gravity="center" android:orientation="horizontal" android:id="@id/llTotalAmount" android:background="@drawable/green" android:padding="15.0dip" android:visibility="gone" android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_alignParentBottom="true">
            <TextView android:textSize="@dimen/margin_20dp" android:textColor="#ffffffff" android:layout_width="fill_parent" android:layout_height="wrap_content" android:text="Total Patients :" android:layout_weight="1.0" />
            <TextView android:textSize="@dimen/font_20sp" android:textColor="#ffffffff" android:gravity="right" android:id="@id/totoalPatient" android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_weight="1.0" />
        </LinearLayout>
    </RelativeLayout>
</LinearLayout>